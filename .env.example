# =============================================================================
# MODELO de ficheiro .env - UrbanEco Analytics / Supercasa Scraper
# =============================================================================
# Copia este ficheiro para um novo ficheiro chamado ".env" (sem ".example"
# no fim) e preenche os valores reais. O ficheiro .env NUNCA deve ser
# enviado para o GitHub (já está listado no .gitignore, por segurança).
#
# No GitHub Actions não é preciso nenhum ficheiro .env - a DATABASE_URL é
# definida como "Secret" do repositório (ver instruções no chat).

# --- Obrigatório -------------------------------------------------------------
# A tua ligação real ao Aiven (Service URI / connection string completa).
# Vai buscar este valor à consola do Aiven: Overview do serviço urbaneco-db.
DATABASE_URL=postgres://avnadmin:A_TUA_PASSWORD_REAL_AQUI@urbaneco-db-migueljteixeira-bigdata.b.aivencloud.com:25973/defaultdb?sslmode=require

# --- Login no Supercasa (opcional, mas recomendado - ver FAZER_LOGIN) ------
# Credenciais pessoais reais - NUNCA committar isto, mesmo neste ficheiro
# de exemplo (por isso aqui só há um placeholder).
SUPERCASA_EMAIL=migueljteixeira2@gmail.com
SUPERCASA_PASSWORD=Qwe123456

# --- Só necessário no Windows com processador ARM (o teu caso local) -------
# Ver explicação completa no topo do supercasa_scraper.py.
CHROME_BINARY=C:\Program Files\Google\Chrome\Application\chrome.exe
CHROMEDRIVER_PATH=C:\WebDriver\chromedriver.exe
VERSAO_CHROME=149

# --- Opcionais (têm valores predefinidos sensatos, só mudar se quiseres) ---
# MODO_HEADLESS=True
# MODO_TESTE=False
